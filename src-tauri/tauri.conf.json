{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yodawg",
  "version": "0.2.3",
  "identifier": "com.yodawg.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "yodawg — QEMU made friendly",
        "width": 1100,
        "height": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "installer/qemu-w64-setup.exe": "qemu-w64-setup.exe"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer/hooks.nsh"
      }
    }
  }
}
